{"file":"index-D52p_mEW.js","mappings":";;;;;;;;;;;;;;;;AAAuD,MAAA,eAAe,gBAAgB,wBAAwB;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;ACAvD,MAAA,aAAe,gBAAgB,0BAA0B;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;ACgChH,UAAM,WAAW;AAAA,MACf;AAAA,QACE,MAAM;AAAA,QACN,OAAO;AAAA,QACP,aAAa;AAAA,MAAA;AAAA,MAEf;AAAA,QACE,MAAM;AAAA,QACN,OAAO;AAAA,QACP,aAAa;AAAA,MAAA;AAAA,MAEf;AAAA,QACE,MAAM;AAAA,QACN,OAAO;AAAA,QACP,aAAa;AAAA,MAAA;AAAA,MAEf;AAAA,QACE,MAAM;AAAA,QACN,OAAO;AAAA,QACP,aAAa;AAAA,MAAA;AAAA,IACf;;;;;;;;;;;;;;;;;;;;;;;;;;;;;ACOF,UAAM,cAAc,IAAmB,CAAC;AAMxC,UAAM,OAAO;AAAA,MACX;AAAA,QACE,UAAU;AAAA,QACV,QAAQ;AAAA,MAAA;AAAA,MAEV;AAAA,QACE,UAAU;AAAA,QACV,QAAQ;AAAA,MAAA;AAAA,MAEV;AAAA,QACE,UAAU;AAAA,QACV,QAAQ;AAAA,MAAA;AAAA,IACV;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AClEF,YAAQ;AAAA,MACN,OAAO;AAAA,MACP,MAAM;AAAA,QACJ,EAAE,MAAM,eAAe,SAAS,uCAAA;AAAA,MAAuC;AAAA,IACzE,CACD;;;;;;;;;;;;;;;;;;;;;;;","names":[],"sources":["../../../../virtual:public?%2Fhero-placeholder.webp","../../../../virtual:public?%2Fperfil-placeholder.webp","../../../../components/sections/Services.vue","../../../../components/sections/Faq.vue","../../../../pages/index.vue"],"sourcesContent":["import { publicAssetsURL } from '#internal/nuxt/paths';export default publicAssetsURL(\"/hero-placeholder.webp\")","import { publicAssetsURL } from '#internal/nuxt/paths';export default publicAssetsURL(\"/perfil-placeholder.webp\")","<template>\n  <section id=\"servicios\" class=\"py-24 bg-white/50 dark:bg-slate-900/50 relative\">\n    <!-- Decoración de fondo -->\n    <div class=\"absolute inset-0 overflow-hidden pointer-events-none\">\n      <div class=\"absolute top-1/2 left-1/4 w-[500px] h-[500px] bg-info/5 dark:bg-info/10 rounded-full blur-[100px] -translate-y-1/2\"></div>\n    </div>\n\n    <div class=\"container mx-auto px-4 relative z-10\">\n      <div class=\"text-center mb-16 max-w-2xl mx-auto service-header opacity-0\">\n        <h2 class=\"text-3xl md:text-4xl font-display font-bold text-slate-900 dark:text-white mb-6\">Mis Servicios Médicos</h2>\n        <p class=\"text-slate-600 dark:text-slate-300\">\n          Enfoque especializado en el diagnóstico, tratamiento no quirúrgico y prevención de enfermedades en adultos.\n        </p>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12\">\n        <div v-for=\"(service, i) in services\" :key=\"i\" class=\"service-card opacity-0 glass-card p-8 group\">\n          <div class=\"w-14 h-14 rounded-2xl bg-gradient-to-br from-primary/10 to-info/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300\">\n            <Icon :name=\"service.icon\" class=\"w-8 h-8 text-primary dark:text-secondary\" />\n          </div>\n          <h3 class=\"text-2xl font-bold text-slate-800 dark:text-white mb-4\">{{ service.title }}</h3>\n          <p class=\"text-slate-600 dark:text-slate-300 leading-relaxed\" v-html=\"service.description\"></p>\n        </div>\n      </div>\n\n    </div>\n  </section>\n</template>\n\n<script setup lang=\"ts\">\nimport { onMounted } from 'vue'\n\nconst services = [\n  {\n    icon: 'lucide:activity',\n    title: 'Manejo de enfermedades crónicas',\n    description: 'Tratamiento integral de <strong>diabetes</strong>, <strong>hipertensión arterial</strong>, enfermedades pulmonares y del riñón, buscando estabilizar su salud a largo plazo.'\n  },\n  {\n    icon: 'lucide:heart-pulse',\n    title: 'Atención a trastornos específicos',\n    description: 'Abordaje experto de enfermedades <strong>endocrinológicas</strong>, renales, hematológicas y <strong>cardiovasculares</strong> con base en protocolos actualizados.'\n  },\n  {\n    icon: 'lucide:shield-plus',\n    title: 'Prevención médica',\n    description: 'Realización de <strong>chequeos preventivos</strong>, tamizaje oportuno de enfermedades silenciosas y <strong>valoración preoperatoria</strong> de alta precisión.'\n  },\n  {\n    icon: 'lucide:stethoscope',\n    title: 'Atención especializada',\n    description: 'Diagnóstico asertivo de patologías complejas, manejo integral de <strong>obesidad</strong> y <strong>segundas opiniones médicas</strong> para su tranquilidad y bienestar.'\n  }\n]\n\nonMounted(() => {\n  const { $gsap } = useNuxtApp()\n  if ($gsap) {\n    const tl = $gsap.timeline({\n      scrollTrigger: {\n        trigger: '#servicios',\n        start: 'top 75%',\n      }\n    })\n    \n    tl.fromTo('.service-header', { y: 30, opacity: 0 }, { y: 0, opacity: 1, duration: 0.6 })\n      .fromTo('.service-card', \n        { y: 50, opacity: 0 }, \n        { y: 0, opacity: 1, duration: 0.6, stagger: 0.2 },\n        '-=0.3'\n      )\n  }\n})\n</script>\n","<template>\n  <section id=\"preguntas\" class=\"py-24 relative\">\n    <div class=\"container mx-auto px-4 max-w-4xl\">\n      <div class=\"text-center mb-16 faq-header opacity-0\">\n        <h2 class=\"text-3xl md:text-4xl font-display font-bold text-slate-900 dark:text-white mb-6\">Preguntas Frecuentes</h2>\n        <div class=\"w-16 h-1 bg-gradient-to-r from-primary to-accent mx-auto rounded-full\"></div>\n      </div>\n\n      <div class=\"space-y-4\">\n        <div v-for=\"(faq, index) in faqs\" :key=\"index\" class=\"faq-item opacity-0 glass-card transition-all duration-300\">\n          <button \n            @click=\"toggleFaq(index)\"\n            class=\"w-full px-6 py-5 flex items-center justify-between text-left focus:outline-none\"\n            :aria-expanded=\"activeIndex === index\"\n          >\n            <span class=\"font-semibold text-slate-800 dark:text-slate-100 pr-8\">{{ faq.question }}</span>\n            <div \n              class=\"flex-shrink-0 w-8 h-8 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center transition-transform duration-300\"\n              :class=\"{ 'rotate-180 bg-primary/10 dark:bg-secondary/10 text-primary dark:text-secondary': activeIndex === index }\"\n            >\n              <Icon name=\"lucide:chevron-down\" class=\"w-5 h-5\" />\n            </div>\n          </button>\n          \n          <div \n            v-show=\"activeIndex === index\"\n            class=\"px-6 pb-6 text-slate-600 dark:text-slate-300 leading-relaxed origin-top\"\n          >\n            <div class=\"pt-2 border-t border-slate-100 dark:border-slate-800\">\n              <p v-html=\"faq.answer\"></p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Emergency Box -->\n      <div class=\"mt-12 glass-card p-8 border-l-4 border-l-red-500 bg-red-50/50 dark:bg-red-950/20 faq-item opacity-0\">\n        <div class=\"flex items-start gap-4\">\n          <div class=\"p-3 bg-red-100 dark:bg-red-900/50 rounded-full text-red-600 dark:text-red-400\">\n            <Icon name=\"lucide:alert-triangle\" class=\"w-6 h-6\" />\n          </div>\n          <div>\n            <h3 class=\"font-bold text-slate-900 dark:text-white mb-2\">Protocolo de Emergencias</h3>\n            <p class=\"text-sm text-slate-600 dark:text-slate-300\">\n              Contamos con una línea especial destinada exclusivamente a situaciones médicas urgentes de pacientes ya valorados: \n              <br class=\"hidden sm:block\"/>\n              <a href=\"tel:3441041492\" class=\"font-bold text-red-600 dark:text-red-400 hover:underline mt-2 inline-block\">344-104-14-92</a>.\n            </p>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </section>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref, onMounted } from 'vue'\n\nconst activeIndex = ref<number | null>(0)\n\nconst toggleFaq = (index: number) => {\n  activeIndex.value = activeIndex.value === index ? null : index\n}\n\nconst faqs = [\n  {\n    question: '¿Cómo llego exactamente al consultorio?',\n    answer: 'Nos encontramos dentro del Centro Oncológico del Hospital MAC SUR. Al llegar, dirígete a la Torre C y sube al consultorio 201.'\n  },\n  {\n    question: '¿Qué padecimientos trata un médico internista?',\n    answer: 'Nos enfocamos en el diagnóstico y tratamiento no quirúrgico de enfermedades que afectan a los órganos internos de los adultos, especialmente <strong>padecimientos crónicos y complejos</strong> (como alteraciones metabólicas, problemas cardiovasculares o respiratorios profundos).'\n  },\n  {\n    question: '¿Atiende pacientes pediátricos o adolescentes?',\n    answer: 'La Medicina Interna se especializa exclusivamente en la atención integral de pacientes <strong>adultos</strong>. Para menores de edad lo ideal es acudir con un Pediatra.'\n  }\n]\n\nonMounted(() => {\n  const { $gsap } = useNuxtApp()\n  if ($gsap) {\n    const tl = $gsap.timeline({\n      scrollTrigger: {\n        trigger: '#preguntas',\n        start: 'top 80%',\n      }\n    })\n    \n    tl.fromTo('.faq-header', { y: 20, opacity: 0 }, { y: 0, opacity: 1, duration: 0.5 })\n      .fromTo('.faq-item', \n        { y: 30, opacity: 0 }, \n        { y: 0, opacity: 1, duration: 0.5, stagger: 0.15 },\n        '-=0.2'\n      )\n  }\n})\n</script>\n","<template>\n  <div>\n    <SectionsHero />\n    <SectionsAbout />\n    <SectionsServices />\n    <SectionsFaq />\n    <SectionsContact />\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nuseHead({\n  title: 'Inicio | Dra. Yissel Mendoza',\n  meta: [\n    { name: 'description', content: 'Médico internista en Aguascalientes.' }\n  ]\n})\n</script>\n"],"version":3}